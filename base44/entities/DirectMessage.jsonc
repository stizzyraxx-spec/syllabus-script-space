{
  "name": "DirectMessage",
  "type": "object",
  "properties": {
    "from_email": {
      "type": "string"
    },
    "to_email": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "conversation_id": {
      "type": "string",
      "description": "Sorted concatenation of the two emails"
    }
  },
  "required": [
    "from_email",
    "to_email",
    "content",
    "conversation_id"
  ]
}