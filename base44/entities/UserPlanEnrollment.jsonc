{
  "name": "UserPlanEnrollment",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "User's email"
    },
    "plan_id": {
      "type": "string",
      "description": "Bible plan ID"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "abandoned"
      ],
      "default": "active"
    },
    "current_day": {
      "type": "number",
      "default": 1,
      "description": "Current day in plan"
    },
    "user_start_date": {
      "type": "string",
      "format": "date",
      "description": "When user started (for self-paced plans)"
    },
    "completed_days": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": [],
      "description": "Days completed by the user"
    }
  },
  "required": [
    "user_email",
    "plan_id"
  ]
}